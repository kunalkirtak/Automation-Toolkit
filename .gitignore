# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg

# ---- Virtual environments ----
venv/
.venv/
env/
ENV/
.python-version

# ---- Testing / coverage ----
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ---- Logs ----
logs/*.log
logs/*.log.*
*.log

# ---- Runtime output (generated by the toolkit, not source) ----
output/*
!output/.gitkeep

# ---- Config overrides (keep local secrets/settings out of git) ----
config.local.json
*.local.json

# ---- IDE / OS ----
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# ---- Jupyter ----
.ipynb_checkpoints/

# ---- Backups produced by automation/backup.py ----
backups/
